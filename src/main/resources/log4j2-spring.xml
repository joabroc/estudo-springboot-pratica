<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="appName">${spring:spring.application.name:-analytics}</Property>
        <Property name="appEnv">${env:APP_ENV:-local}</Property>
    </Properties>

    <Appenders>
        <Console name="ConsoleJson" target="SYSTEM_OUT">
            <JsonTemplateLayout eventTemplateUri="classpath:log4j2-event-template.json"/>
        </Console>
    </Appenders>

    <Loggers>
        <Logger name="org.springframework" level="INFO"/>
        <Root level="INFO">
            <AppenderRef ref="ConsoleJson"/>
        </Root>
    </Loggers>
</Configuration>

